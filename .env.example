# Copy to .env.local for local dev; set the same vars in Vercel for deploys.
# Values live in the Supabase dashboard: Project Settings -> API.

# Supabase project URL (safe to expose).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon/publishable key (safe to expose; RLS enforces access).
# Either the legacy anon JWT or a modern sb_publishable_... key works.
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-or-publishable-key>

# Direct Postgres connection string for ingest scripts (Phase 2+).
# SERVER-ONLY: never expose, never prefix with NEXT_PUBLIC.
# Dashboard -> Project Settings -> Database -> Connection string (URI).
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
